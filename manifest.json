{
  "manifest_version": 3,
  "name": "ClipVault",
  "version": "0.1.0",
  "description": "Low-friction clipping for images and text — auto-tag, assign to a project, find them back in a waterfall library.",
  "permissions": ["contextMenus", "storage", "unlimitedStorage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "service-worker.js" },
  "action": { "default_title": "Open ClipVault library", "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" } },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
